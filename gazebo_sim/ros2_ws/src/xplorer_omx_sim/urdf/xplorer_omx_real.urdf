  <gazebo reference="wheel_fr">
    <mu1>1.1</mu1><mu2>0.18</mu2>
    <fdir1>1 0 0</fdir1>
  </gazebo>
  <gazebo reference="wheel_fl">
    <mu1>1.1</mu1><mu2>0.18</mu2>
    <fdir1>1 0 0</fdir1>
  </gazebo>
  <gazebo reference="wheel_rl">
    <mu1>1.1</mu1><mu2>0.18</mu2>
    <fdir1>1 0 0</fdir1>
  </gazebo>
  <gazebo reference="wheel_rr">
    <mu1>1.1</mu1><mu2>0.18</mu2>
    <fdir1>1 0 0</fdir1>
  </gazebo>
  <gazebo reference="finger_left">
    <mu1>2.5</mu1><mu2>2.5</mu2>
