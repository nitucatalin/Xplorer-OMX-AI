<?xml version="1.0"?>
<!-- ==========================================================================
  xplorer_omx.urdf — model simplificat echivalent al ansamblului
  Xplorer-A (platforma diff-drive + LiDAR 2D tip LD19) + brat OMX-AI-F
  (6 axe: shoulder_pan, shoulder_lift, elbow_flex, wrist_flex, wrist_roll,
   gripper cu 2 degete prismatice).
  Cinematica/dimensiunile aproximeaza robotul real; URDF-ul Onshape original
  (505 link-uri, mase CAD nerealiste) nu este utilizabil direct in fizica
  Gazebo, deci aici geometria e simplificata dar echivalenta functional.
=========================================================================== -->
<robot name="xplorer_omx">

  <material name="dark_grey"><color rgba="0.25 0.25 0.25 1"/></material>
  <material name="light_grey"><color rgba="0.6 0.6 0.6 1"/></material>
  <material name="black"><color rgba="0.08 0.08 0.08 1"/></material>
  <material name="white"><color rgba="0.9 0.9 0.9 1"/></material>
  <material name="blue"><color rgba="0.1 0.3 0.7 1"/></material>

  <!-- ============================== SASIU ============================== -->
  <link name="base_link">
    <inertial>
      <mass value="9.0"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.0915" ixy="0" ixz="0" iyy="0.1470" iyz="0" izz="0.2091"/>
    </inertial>
    <visual>
      <geometry><box size="0.42 0.32 0.14"/></geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <geometry><box size="0.42 0.32 0.14"/></geometry>
    </collision>
  </link>

  <!-- ============================== ROTI ================================ -->
  <link name="left_wheel">
    <inertial>
      <mass value="0.6"/>
      <inertia ixx="0.00104" ixy="0" ixz="0" iyy="0.00104" iyz="0" izz="0.00192"/>
    </inertial>
    <visual>
      <origin rpy="1.5707963 0 0"/>
      <geometry><cylinder radius="0.08" length="0.04"/></geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin rpy="1.5707963 0 0"/>
      <geometry><cylinder radius="0.08" length="0.04"/></geometry>
    </collision>
  </link>
  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <origin xyz="0 0.18 -0.04"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.05" friction="0.05"/>
  </joint>

  <link name="right_wheel">
    <inertial>
      <mass value="0.6"/>
      <inertia ixx="0.00104" ixy="0" ixz="0" iyy="0.00104" iyz="0" izz="0.00192"/>
    </inertial>
    <visual>
      <origin rpy="1.5707963 0 0"/>
      <geometry><cylinder radius="0.08" length="0.04"/></geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin rpy="1.5707963 0 0"/>
      <geometry><cylinder radius="0.08" length="0.04"/></geometry>
    </collision>
  </link>
  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <origin xyz="0 -0.18 -0.04"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.05" friction="0.05"/>
  </joint>

  <!-- ============================ CASTERE =============================== -->
  <link name="caster_front">
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.0002" ixy="0" ixz="0" iyy="0.0002" iyz="0" izz="0.0002"/>
    </inertial>
    <visual>
      <geometry><sphere radius="0.05"/></geometry>
      <material name="light_grey"/>
    </visual>
    <collision>
      <geometry><sphere radius="0.05"/></geometry>
    </collision>
  </link>
  <joint name="caster_front_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_front"/>
    <origin xyz="0.155 0 -0.07"/>
  </joint>

  <link name="caster_rear">
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.0002" ixy="0" ixz="0" iyy="0.0002" iyz="0" izz="0.0002"/>
    </inertial>
    <visual>
      <geometry><sphere radius="0.05"/></geometry>
      <material name="light_grey"/>
    </visual>
    <collision>
      <geometry><sphere radius="0.05"/></geometry>
    </collision>
  </link>
  <joint name="caster_rear_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_rear"/>
    <origin xyz="-0.155 0 -0.07"/>
  </joint>

  <!-- ====================== LIDAR (echivalent LD19) ===================== -->
  <link name="lidar_link">
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
    <visual>
      <geometry><cylinder radius="0.025" length="0.035"/></geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <geometry><cylinder radius="0.025" length="0.035"/></geometry>
    </collision>
  </link>
  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <origin xyz="0.17 0 0.12"/>
  </joint>

  <!-- ===================== BRAT OMX-AI (simplificat) ===================== -->
  <link name="arm_base_link">
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.0002" ixy="0" ixz="0" iyy="0.0002" iyz="0" izz="0.0002"/>
    </inertial>
    <visual>
      <geometry><cylinder radius="0.04" length="0.05"/></geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry><cylinder radius="0.04" length="0.05"/></geometry>
    </collision>
  </link>
  <joint name="arm_base_joint" type="fixed">
    <parent link="base_link"/>
    <child link="arm_base_link"/>
    <origin xyz="0.0 0 0.095"/>
  </joint>

  <link name="shoulder_link">
    <inertial>
      <mass value="0.15"/>
      <inertia ixx="0.0002" ixy="0" ixz="0" iyy="0.0002" iyz="0" izz="0.0002"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.02"/>
      <geometry><cylinder radius="0.035" length="0.06"/></geometry>
      <material name="white"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.02"/>
      <geometry><cylinder radius="0.035" length="0.06"/></geometry>
    </collision>
  </link>
  <joint name="shoulder_pan" type="revolute">
    <parent link="arm_base_link"/>
    <child link="shoulder_link"/>
    <origin xyz="0 0 0.035"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.1415" upper="3.1415" effort="10" velocity="3.0"/>
    <dynamics damping="0.1" friction="0.05"/>
  </joint>

  <link name="upper_arm_link">
    <inertial>
      <mass value="0.13"/>
      <origin xyz="0 0 0.065"/>
      <inertia ixx="0.0002" ixy="0" ixz="0" iyy="0.0002" iyz="0" izz="0.0001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.065"/>
      <geometry><box size="0.045 0.045 0.13"/></geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.065"/>
      <geometry><box size="0.045 0.045 0.13"/></geometry>
    </collision>
  </link>
  <joint name="shoulder_lift" type="revolute">
    <parent link="shoulder_link"/>
    <child link="upper_arm_link"/>
    <origin xyz="0 0 0.05"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.9" upper="1.9" effort="10" velocity="3.0"/>
    <dynamics damping="0.1" friction="0.05"/>
  </joint>

  <link name="forearm_link">
    <inertial>
      <mass value="0.11"/>
      <origin xyz="0 0 0.062"/>
      <inertia ixx="0.00015" ixy="0" ixz="0" iyy="0.00015" iyz="0" izz="0.0001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.062"/>
      <geometry><box size="0.04 0.04 0.124"/></geometry>
      <material name="white"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.062"/>
      <geometry><box size="0.04 0.04 0.124"/></geometry>
    </collision>
  </link>
  <joint name="elbow_flex" type="revolute">
    <parent link="upper_arm_link"/>
    <child link="forearm_link"/>
    <origin xyz="0 0 0.13"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.9" upper="1.9" effort="10" velocity="3.0"/>
    <dynamics damping="0.1" friction="0.05"/>
  </joint>

  <link name="wrist_link">
    <inertial>
      <mass value="0.07"/>
      <origin xyz="0 0 0.025"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.025"/>
      <geometry><box size="0.035 0.035 0.05"/></geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.025"/>
      <geometry><box size="0.035 0.035 0.05"/></geometry>
    </collision>
  </link>
  <joint name="wrist_flex" type="revolute">
    <parent link="forearm_link"/>
    <child link="wrist_link"/>
    <origin xyz="0 0 0.124"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.9" upper="1.9" effort="8" velocity="3.0"/>
    <dynamics damping="0.1" friction="0.05"/>
  </joint>

  <link name="gripper_base_link">
    <inertial>
      <mass value="0.06"/>
      <origin xyz="0 0 0.015"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.015"/>
      <geometry><box size="0.04 0.07 0.03"/></geometry>
      <material name="white"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.015"/>
      <geometry><box size="0.04 0.07 0.03"/></geometry>
    </collision>
  </link>
  <joint name="wrist_roll" type="revolute">
    <parent link="wrist_link"/>
    <child link="gripper_base_link"/>
    <origin xyz="0 0 0.05"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.1415" upper="3.1415" effort="5" velocity="3.0"/>
    <dynamics damping="0.1" friction="0.05"/>
  </joint>

  <!-- degete gripper (prismatice, comandate identic = deschidere simetrica) -->
  <link name="finger_left">
    <inertial>
      <mass value="0.02"/>
      <origin xyz="0 0 0.022"/>
      <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.022"/>
      <geometry><box size="0.012 0.006 0.045"/></geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.022"/>
      <geometry><box size="0.012 0.006 0.045"/></geometry>
    </collision>
  </link>
  <joint name="gripper_left" type="prismatic">
    <parent link="gripper_base_link"/>
    <child link="finger_left"/>
    <origin xyz="0 0.012 0.03"/>
    <axis xyz="0 1 0"/>
    <limit lower="0.0" upper="0.022" effort="10" velocity="0.1"/>
    <dynamics damping="0.5" friction="0.1"/>
  </joint>

  <link name="finger_right">
    <inertial>
      <mass value="0.02"/>
      <origin xyz="0 0 0.022"/>
      <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.022"/>
      <geometry><box size="0.012 0.006 0.045"/></geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.022"/>
      <geometry><box size="0.012 0.006 0.045"/></geometry>
    </collision>
  </link>
  <joint name="gripper_right" type="prismatic">
    <parent link="gripper_base_link"/>
    <child link="finger_right"/>
    <origin xyz="0 -0.012 0.03"/>
    <axis xyz="0 -1 0"/>
    <limit lower="0.0" upper="0.022" effort="10" velocity="0.1"/>
    <dynamics damping="0.5" friction="0.1"/>
  </joint>

  <!-- ========================= EXTENSII GAZEBO ========================== -->

  <!-- castere fara frecare (alunecare libera) -->
  <gazebo reference="caster_front">
    <mu1>0.001</mu1><mu2>0.001</mu2>
  </gazebo>
  <gazebo reference="caster_rear">
    <mu1>0.001</mu1><mu2>0.001</mu2>
  </gazebo>
  <gazebo reference="left_wheel">
    <mu1>1.2</mu1><mu2>1.0</mu2>
  </gazebo>
  <gazebo reference="right_wheel">
    <mu1>1.2</mu1><mu2>1.0</mu2>
  </gazebo>

  <!-- senzor LiDAR 2D (echivalent LD19: 360 grade, 10 Hz, 12 m) -->
  <gazebo reference="lidar_link">
    <sensor name="ld19" type="gpu_lidar">
      <topic>/scan_gz</topic>
      <update_rate>10</update_rate>
      <gz_frame_id>lidar_link</gz_frame_id>
      <lidar>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.25</min>
          <max>12.0</max>
          <resolution>0.01</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </lidar>
      <always_on>1</always_on>
      <visualize>true</visualize>
    </sensor>
  </gazebo>

  <!-- plugin diff-drive (echivalent diff_drive_controller + RoboClaw) -->
  <gazebo>
    <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>0.36</wheel_separation>
      <wheel_radius>0.08</wheel_radius>
      <topic>/model/xplorer_omx/cmd_vel</topic>
      <odom_topic>/model/xplorer_omx/odometry</odom_topic>
      <tf_topic>/model/xplorer_omx/tf</tf_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_link</child_frame_id>
      <odom_publish_frequency>30</odom_publish_frequency>
      <max_linear_acceleration>1.0</max_linear_acceleration>
      <max_angular_acceleration>2.0</max_angular_acceleration>
    </plugin>

    <plugin filename="gz-sim-joint-state-publisher-system"
            name="gz::sim::systems::JointStatePublisher">
      <topic>/model/xplorer_omx/joint_states</topic>
    </plugin>

    <!-- controllere de pozitie per articulatie (echivalent Dynamixel
         Operating_Mode pozitie + PID, ca in omx_follower.configure()) -->
    <plugin filename="gz-sim-joint-position-controller-system"
            name="gz::sim::systems::JointPositionController">
      <joint_name>shoulder_pan</joint_name>
      <topic>/arm/shoulder_pan/cmd_pos</topic>
      <p_gain>15.0</p_gain><i_gain>0.2</i_gain><d_gain>1.0</d_gain>
      <i_max>1</i_max><i_min>-1</i_min>
      <cmd_max>10</cmd_max><cmd_min>-10</cmd_min>
    </plugin>
    <plugin filename="gz-sim-joint-position-controller-system"
            name="gz::sim::systems::JointPositionController">
      <joint_name>shoulder_lift</joint_name>
      <topic>/arm/shoulder_lift/cmd_pos</topic>
      <p_gain>25.0</p_gain><i_gain>0.5</i_gain><d_gain>1.5</d_gain>
      <i_max>2</i_max><i_min>-2</i_min>
      <cmd_max>12</cmd_max><cmd_min>-12</cmd_min>
    </plugin>
    <plugin filename="gz-sim-joint-position-controller-system"
            name="gz::sim::systems::JointPositionController">
      <joint_name>elbow_flex</joint_name>
      <topic>/arm/elbow_flex/cmd_pos</topic>
      <p_gain>20.0</p_gain><i_gain>0.4</i_gain><d_gain>1.2</d_gain>
      <i_max>2</i_max><i_min>-2</i_min>
      <cmd_max>10</cmd_max><cmd_min>-10</cmd_min>
    </plugin>
    <plugin filename="gz-sim-joint-position-controller-system"
            name="gz::sim::systems::JointPositionController">
      <joint_name>wrist_flex</joint_name>
      <topic>/arm/wrist_flex/cmd_pos</topic>
      <p_gain>10.0</p_gain><i_gain>0.2</i_gain><d_gain>0.6</d_gain>
      <i_max>1</i_max><i_min>-1</i_min>
      <cmd_max>8</cmd_max><cmd_min>-8</cmd_min>
    </plugin>
    <plugin filename="gz-sim-joint-position-controller-system"
            name="gz::sim::systems::JointPositionController">
      <joint_name>wrist_roll</joint_name>
      <topic>/arm/wrist_roll/cmd_pos</topic>
      <p_gain>6.0</p_gain><i_gain>0.1</i_gain><d_gain>0.4</d_gain>
      <i_max>1</i_max><i_min>-1</i_min>
      <cmd_max>5</cmd_max><cmd_min>-5</cmd_min>
    </plugin>
    <plugin filename="gz-sim-joint-position-controller-system"
            name="gz::sim::systems::JointPositionController">
      <joint_name>gripper_left</joint_name>
      <topic>/arm/gripper_left/cmd_pos</topic>
      <p_gain>120.0</p_gain><i_gain>1.0</i_gain><d_gain>2.0</d_gain>
      <i_max>5</i_max><i_min>-5</i_min>
      <cmd_max>20</cmd_max><cmd_min>-20</cmd_min>
    </plugin>
    <plugin filename="gz-sim-joint-position-controller-system"
            name="gz::sim::systems::JointPositionController">
      <joint_name>gripper_right</joint_name>
      <topic>/arm/gripper_right/cmd_pos</topic>
      <p_gain>120.0</p_gain><i_gain>1.0</i_gain><d_gain>2.0</d_gain>
      <i_max>5</i_max><i_min>-5</i_min>
      <cmd_max>20</cmd_max><cmd_min>-20</cmd_min>
    </plugin>
  </gazebo>

</robot>
